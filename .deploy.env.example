# คัดลอกไฟล์นี้เป็น .deploy.env แล้วใส่คีย์จริง (ไฟล์ .deploy.env ถูก gitignore ไม่ถูก commit)
# ใช้โดย deploy.sh เพื่อตั้ง Supabase Fn secrets — ปล่อยว่างได้ถ้าตั้งไว้แล้วบน dashboard
export ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
export SERPER_API_KEY=xxxxxxxx
export RESEND_API_KEY=re_xxxxxxxx
export CRON_SECRET=xxxxxxxx
