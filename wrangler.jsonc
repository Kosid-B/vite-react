{
  "name": "ceo-ai-thailand",
  "main": "src/server.ts",
  "compatibility_date": "2026-06-11",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "CeoAiAgent",
        "class_name": "CeoAiAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_classes": ["CeoAiAgent"]
    }
  ],
  // Custom domain production — ผูกโดเมนกับ Worker (แทน A records → GitHub Pages ที่เป็น legacy)
  // custom_domain: true → Cloudflare สร้าง DNS + edge certificate ให้อัตโนมัติตอน deploy
  // (ต้องมีโซน ceoaithailand.org ในบัญชี Cloudflare เดียวกับ Worker — ดู docs/ops/GO-LIVE-CHECKLIST.md)
  "routes": [
    { "pattern": "ceoaithailand.org", "custom_domain": true },
    { "pattern": "www.ceoaithailand.org", "custom_domain": true }
  ],
  "vars": {
    "ANTHROPIC_API_KEY": "",
    // ค่า public (ไม่ใช่ secret) — ใช้อ่านตาราง storefronts เพื่อทำ SEO ฝั่ง server (/b/<slug>, /sitemap.xml)
    // ใช้ publishable key (sb_publishable_…) = public โดยดีไซน์ + rotate แยกได้ (เลี่ยง anon JWT ที่ scanner ตีว่าเป็น secret)
    // production Supabase = waigsnxhrlwtiotspaim (ย้ายจาก rsjbqmnvocvtveelselj — ก.ค. 2569)
    "SUPABASE_URL": "https://waigsnxhrlwtiotspaim.supabase.co",
    "SUPABASE_ANON_KEY": "sb_publishable_Tf6Q7Mq6I2OLtfXot-EWJA_FESohA9E",
    "SITE_ORIGIN": "https://ceoaithailand.org"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": true,
      "persist": true,
      "head_sampling_rate": 1
    }
  }
}
