{
  "name": "ceo-ai-thailand",
  "main": "src/server.ts",
  "compatibility_date": "2026-06-11",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "CeoAiAgent",
        "class_name": "CeoAiAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_classes": ["CeoAiAgent"]
    }
  ],
  "vars": {
    "ANTHROPIC_API_KEY": "",
    // ค่า public (ไม่ใช่ secret) — ใช้อ่านตาราง storefronts เพื่อทำ SEO ฝั่ง server (/b/<slug>, /sitemap.xml)
    // ใช้ publishable key (sb_publishable_…) = public โดยดีไซน์ + rotate แยกได้ (เลี่ยง anon JWT ที่ scanner ตีว่าเป็น secret)
    // production Supabase = rsjbqmnvocvtveelselj เท่านั้น
    "SUPABASE_URL": "https://rsjbqmnvocvtveelselj.supabase.co",
    "SUPABASE_ANON_KEY": "sb_publishable_UCZESix8lLZ4yDU0hEZMkQ_RL-Lk-te",
    "SITE_ORIGIN": "https://ceoaithailand.org"
  },
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  }
}
